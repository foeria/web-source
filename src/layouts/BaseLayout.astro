---
import SiteHeader from "../components/layout/SiteHeader.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import { withBase } from "../lib/site";
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "酒酒的奇妙空间" } = Astro.props;
---

<!doctype html>
<html
  lang="zh-CN"
  data-theme="light"
  style={`--site-bg-image-main: url("${withBase("/assets/decor/site-background.jpg")}")`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Source+Sans+3:wght@300;400;600&family=Noto+Serif+SC:wght@400;600&family=Noto+Sans+SC:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
