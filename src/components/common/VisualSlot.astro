---
type Props = {
  title?: string;
  subtitle?: string;
  minHeight?: string;
  floating?: boolean;
  compact?: boolean;
  showText?: boolean;
  src?: string;
  alt?: string;
  href?: string;
  lightbox?: boolean;
};

const {
  title = "视觉插图",
  subtitle = "用于放置角色立绘、封面图或横幅插画。",
  minHeight = "240px",
  floating = false,
  compact = false,
  showText = false,
  src,
  alt = title,
  href,
  lightbox = false,
} = Astro.props;

const isLinked = Boolean(src && href);
const isLightbox = Boolean(src && lightbox);
---

<div
  class:list={[
    "image-slot",
    "visual-slot",
    floating && "floaty",
    src && "image-slot--clean",
    (isLinked || isLightbox) && "visual-slot--linked",
  ]}
  style={`min-height:${minHeight};`}
>
  {src && lightbox ? (
    <button
      class="visual-slot__button"
      type="button"
      data-lightbox-src={src}
      data-lightbox-alt={alt}
      aria-label={`查看大图：${alt}`}
    >
      <img class="visual-slot__image" src={src} alt={alt} loading="lazy" />
    </button>
  ) : src && href ? (
    <a class="visual-slot__link" href={href} target="_blank" rel="noreferrer" aria-label={`查看原图：${alt}`}>
      <img class="visual-slot__image" src={src} alt={alt} loading="lazy" />
    </a>
  ) : src ? (
    <img class="visual-slot__image" src={src} alt={alt} loading="lazy" />
  ) : null}
  {showText ? (
    <div class="visual-slot__inner">
      <span class="pill">{compact ? "Visual" : "Image Slot"}</span>
      <strong>{title}</strong>
      <div class="visual-slot__caption">{subtitle}</div>
    </div>
  ) : null}
</div>
