---
type Props = {
  title?: string;
  subtitle?: string;
  minHeight?: string;
  floating?: boolean;
  compact?: boolean;
  showText?: boolean;
  src?: string;
  alt?: string;
};

const {
  title = "视觉插画",
  subtitle = "用于放置角色立绘、封面图或横幅插画。",
  minHeight = "240px",
  floating = false,
  compact = false,
  showText = false,
  src,
  alt = title,
} = Astro.props;
---

<div class:list={["image-slot", "visual-slot", floating && "floaty", src && "image-slot--clean"]} style={`min-height:${minHeight};`}>
  {src ? <img class="visual-slot__image" src={src} alt={alt} loading="lazy" /> : null}
  {showText ? (
    <div class="visual-slot__inner">
      <span class="pill">{compact ? "Visual" : "Image Slot"}</span>
      <strong>{title}</strong>
      <div class="visual-slot__caption">{subtitle}</div>
    </div>
  ) : null}
</div>
