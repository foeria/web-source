---
import { render } from "astro:content";
import VisualSlot from "../../components/common/VisualSlot.astro";
import ResourceTabs from "../../components/resource/ResourceTabs";
import ResourceCard from "../../components/ui/ResourceCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";
import {
  formatDate,
  getAllResources,
  getCategoryMeta,
  getRelatedResources,
} from "../../lib/content";

export async function getStaticPaths() {
  const resources = await getAllResources();
  return resources.map((resource) => ({
    params: { slug: resource.slug },
    props: { resource },
  }));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
const resources = await getAllResources();
const related = getRelatedResources(resource, resources);
const category = getCategoryMeta(resource.data.category);
const usageImages =
  resource.data.gallery.length > 0 ? resource.data.gallery : [resource.data.cover];
const usageSteps =
  resource.data.usageSteps.length > 0
    ? resource.data.usageSteps
    : usageImages.map((image, index) => ({
        title: `步骤 ${index + 1}`,
        description:
          "依次查看安装、授权、配置和统计等核心流程，快速完成软件上手。",
        image,
      }));
---

<BaseLayout title={`${resource.data.title} | ${siteConfig.name}`} description={resource.data.summary}>
  <section class="container page-section stack">
    <div class="meta-row">
      <a class="pill" href="/">首页</a>
      <a class="pill" href={`/category/${resource.data.category}/`}>
        {category?.name ?? resource.data.category}
      </a>
      <span class="pill">{resource.data.title}</span>
    </div>

    <div class="download-grid resource-detail-layout">
      <div class="card stack resource-detail-card">
        <div class="eyebrow">Software Detail</div>
        <h1 class="section-title">{resource.data.title}</h1>
        <p class="section-subtitle resource-detail-summary" style="margin-top:0;">{resource.data.summary}</p>

        <div class="meta-row">
          <span class="pill">{category?.name}</span>
          {resource.data.platform.map((item) => (
            <span class="pill">{item}</span>
          ))}
          <span class="pill">版本 {resource.data.version}</span>
          <span class="pill">{resource.data.fileFormat}</span>
          <span class="pill">{resource.data.fileSize}</span>
        </div>

        <div style="color:var(--text-muted);">更新于 {formatDate(resource.data.updatedAt)}</div>

        <VisualSlot
          minHeight="clamp(220px, 62vw, 360px)"
          src={resource.data.cover}
          alt={`${resource.data.title} 封面图`}
          lightbox={true}
        />

        <div class="prose">
          <h2>软件介绍</h2>
          <p>{resource.data.overview ?? resource.data.summary}</p>
        </div>
      </div>

      <aside class="card sticky-panel resource-download-panel">
        <div class="stack resource-download-stack">
          <div class="eyebrow">Download & Contact</div>
          <h2 style="margin:0;">下载与联系</h2>

          <div class="stack surface resource-download-box">
            <div>
              <strong>百度网盘</strong>
              <div style="margin-top:8px;word-break:break-all;">
                <a href={resource.data.baiduPanUrl} target="_blank" rel="noreferrer">
                  {resource.data.baiduPanUrl}
                </a>
              </div>
            </div>
            <div>
              <strong>提取码</strong>
              <div style="margin-top:8px;">
                <span class="pill">{resource.data.extractCode}</span>
              </div>
            </div>
            <div style="color:var(--text-muted);line-height:1.8;">{resource.data.downloadNote}</div>
            <div class="resource-download-actions">
              <a class="button" href={resource.data.baiduPanUrl} target="_blank" rel="noreferrer">
                前往下载
              </a>
              <button class="button-secondary" type="button" data-copy-code={resource.data.extractCode}>
                复制提取码
              </button>
            </div>
          </div>

          <div style="height:1px;background:var(--line);"></div>

          <div class="stack surface resource-profile-box">
            <strong style="font-size:1.05rem;">{siteConfig.profile.title}</strong>
            <p style="margin:0;color:var(--text-muted);line-height:1.8;">
              {siteConfig.profile.bio}
            </p>
          </div>

          <div class="stack resource-contact-list">
            <div>
              <strong>承接方向</strong>
              <p style="margin:8px 0 0;color:var(--text-muted);line-height:1.8;">
                {siteConfig.profile.services}
              </p>
            </div>
            {siteConfig.profile.socials.map((item) => (
              <div class="resource-contact-row">
                <span style="color:var(--text-muted);">{item.label}</span>
                {item.href ? (
                  <a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
                    {item.value}
                  </a>
                ) : (
                  <strong>{item.value}</strong>
                )}
              </div>
            ))}
          </div>
        </div>
      </aside>
    </div>

    <div class="stack">
      <div>
        <div class="eyebrow">Usage Guide</div>
        <h2 class="section-title">软件使用方法</h2>
        <p class="section-subtitle">
          下方整理了这款软件的核心上手流程，方便你快速完成安装、配置与日常使用。
        </p>
      </div>

      {resource.data.tutorial ? (
        <article class="card prose resource-tutorial-card">
          <p>{resource.data.tutorial}</p>
        </article>
      ) : null}

      <div class="grid-3">
        {usageSteps.map((step, index) => (
          <div class="card stack usage-step-card resource-step-card">
            <VisualSlot
              minHeight="clamp(180px, 52vw, 220px)"
              src={step.image ?? usageImages[index] ?? resource.data.cover}
              alt={`${resource.data.title} 使用流程图 ${index + 1}`}
              lightbox={true}
            />
            <div class="eyebrow">Step {index + 1}</div>
            <h3 style="margin:0;font-size:1.08rem;">{step.title}</h3>
            <p style="margin:0;color:var(--text-muted);line-height:1.8;">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <ResourceTabs
      client:load
      overview={resource.data.overview}
      tutorial={resource.data.tutorial}
      changelog={resource.data.changelog}
      notes={resource.data.notes}
    />

    <article class="card prose resource-content-card">
      <Content />
    </article>

    <div class="stack">
      <div class="eyebrow">Related</div>
      <h2 class="section-title">相关资源</h2>
      <div class="grid-3">
        {related.map((item) => (
          <ResourceCard
            href={`/resource/${item.slug}/`}
            title={item.data.title}
            summary={item.data.summary}
            tags={item.data.tags}
            updatedAt={item.data.updatedAt}
            categoryLabel={getCategoryMeta(item.data.category)?.name}
            platform={item.data.platform}
            imageSrc={item.data.cover}
          />
        ))}
      </div>
    </div>
  </section>

  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox__backdrop" type="button" data-lightbox-close aria-label="关闭图片预览"></button>
    <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="图片预览">
      <button class="lightbox__close" type="button" data-lightbox-close aria-label="关闭图片预览">
        ×
      </button>
      <img class="lightbox__image" src="" alt="" data-lightbox-image />
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll("[data-copy-code]").forEach((button) => {
      button.addEventListener("click", async () => {
        const value = button.getAttribute("data-copy-code");
        if (!value) return;
        await navigator.clipboard.writeText(value);
        button.textContent = "已复制提取码";
      });
    });

    const lightbox = document.querySelector("[data-lightbox]");
    const lightboxImage = document.querySelector("[data-lightbox-image]");
    const lightboxOpeners = document.querySelectorAll("[data-lightbox-src]");
    const lightboxClosers = document.querySelectorAll("[data-lightbox-close]");

    const closeLightbox = () => {
      if (!lightbox || !lightboxImage) return;
      lightbox.setAttribute("hidden", "");
      document.body.style.overflow = "";
      lightboxImage.setAttribute("src", "");
      lightboxImage.setAttribute("alt", "");
    };

    lightboxOpeners.forEach((button) => {
      button.addEventListener("click", () => {
        const src = button.getAttribute("data-lightbox-src");
        const alt = button.getAttribute("data-lightbox-alt") ?? "";
        if (!lightbox || !lightboxImage || !src) return;
        lightboxImage.setAttribute("src", src);
        lightboxImage.setAttribute("alt", alt);
        lightbox.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
      });
    });

    lightboxClosers.forEach((button) => {
      button.addEventListener("click", closeLightbox);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeLightbox();
    });
  </script>
</BaseLayout>
