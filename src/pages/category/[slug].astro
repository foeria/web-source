---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResourceCard from "../../components/ui/ResourceCard.astro";
import { categories } from "../../data/categories";
import { siteConfig } from "../../data/site";
import { withBase } from "../../lib/site";
import { getAllResources } from "../../lib/content";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const resources = (await getAllResources()).filter(
  (item) => item.data.category === category.slug,
);
---

<BaseLayout title={`${category.name} | ${siteConfig.name}`} description={category.description}>
  <section class="container page-section stack">
    <div class="card stack" style="padding:24px;">
      <div class="eyebrow">Category</div>
      <h1 class="section-title">{category.name}</h1>
      <p class="section-subtitle">{category.description}</p>
    </div>

    <div class="grid-3">
      {resources.map((item) => (
        <ResourceCard
          href={withBase(`/resource/${item.slug}/`)}
          title={item.data.title}
          summary={item.data.summary}
          tags={item.data.tags}
          updatedAt={item.data.updatedAt}
          categoryLabel={category.name}
          platform={item.data.platform}
          imageSrc={item.data.cover}
        />
      ))}
    </div>
  </section>
</BaseLayout>
